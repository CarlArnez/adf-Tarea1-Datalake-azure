{
	"name": "df_vente_scz_bronce_silver",
	"properties": {
		"folder": {
			"name": "Bronce"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "Ventas_SCZ",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ventas_sc_limpio_csv",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "derivedColumn4"
				},
				{
					"name": "filter1"
				},
				{
					"name": "select1"
				},
				{
					"name": "derivedColumn5"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_venta as string,",
				"          fecha as string,",
				"          producto as string,",
				"          cantidad as string,",
				"          precio_unitario as string,",
				"          sucursal as string,",
				"          vendedor as string,",
				"          cliente_nombre as string,",
				"          cliente_email as string,",
				"          metodo_pago as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(vendedor = trim(vendedor),",
				"          cliente_nombre = trim(cliente_nombre),",
				"          producto = trim(producto)) ~> derivedColumn1",
				"derivedColumn1 derive(producto = initCap(regexReplace(producto,'\\\\s+',' ')),",
				"          sucursal = iif(in(['SCZ','SC','Santa Cruz','Sta Cruz','santa cruz','SANTA CRUZ','Sta. Cruz',' sc'],sucursal),'Santa Cruz',sucursal)) ~> derivedColumn2",
				"derivedColumn2 derive(precio_unitario = toFloat(regexReplace(toString(precio_unitario),'^0-9.','')),",
				"          cantidad = toInteger(cantidad)) ~> derivedColumn3",
				"derivedColumn3 derive(fecha = coalesce(\r",
				"    toDate(fecha, 'yyyy-MM-dd'),\r",
				"    toDate(fecha, 'dd-MM-yyyy'),\r",
				"    toDate(fecha, 'MM-dd-yyyy'),\r",
				"    toDate(fecha, 'dd/MM/yyyy'),\r",
				"    toDate(fecha, 'yyyy/MM/dd'),\r",
				"    toDate(fecha, 'dd-MMM-yyyy'),\r",
				"    toDate(fecha, 'dd/MMM/yyyy'),\r",
				"\r",
				"    /* NUEVO formato tipo \"January 09, 2024\" */\r",
				"    toDate(fecha, 'MMMM dd, yyyy'),\r",
				"\r",
				"    /* manejo de fechas con texto tipo \"07 de abril de 2024\" */\r",
				"    toDate(\r",
				"        replace(\r",
				"            replace(\r",
				"                replace(\r",
				"                    replace(\r",
				"                        replace(\r",
				"                            replace(\r",
				"                                replace(\r",
				"                                    replace(\r",
				"                                        replace(\r",
				"                                            replace(\r",
				"                                                replace(\r",
				"                                                    replace(\r",
				"                                                        replace(fecha, ' de ', ' '),\r",
				"                                                        'enero','january'\r",
				"                                                    ),\r",
				"                                                    'febrero','february'\r",
				"                                                ),\r",
				"                                                'marzo','march'\r",
				"                                            ),\r",
				"                                            'abril','april'\r",
				"                                        ),\r",
				"                                        'mayo','may'\r",
				"                                    ),\r",
				"                                    'junio','june'\r",
				"                                ),\r",
				"                                'julio','july'\r",
				"                            ),\r",
				"                            'agosto','august'\r",
				"                        ),\r",
				"                        'septiembre','september'\r",
				"                    ),\r",
				"                    'octubre','october'\r",
				"                ),\r",
				"                'noviembre','november'\r",
				"            ),\r",
				"            'auguts','august'\r",
				"        ),\r",
				"        'dd MMMM yyyy'\r",
				"    )\r",
				")) ~> derivedColumn4",
				"derivedColumn4 filter(cantidad>0 && !isNull (precio_unitario) && !isNull (fecha) && !isNull (metodo_pago)) ~> filter1",
				"filter1 select(mapColumn(",
				"          id_venta,",
				"          fecha,",
				"          producto,",
				"          cantidad,",
				"          precio_unitario,",
				"          sucursal,",
				"          vendedor,",
				"          cliente_nombre,",
				"          cliente_email,",
				"          metodo_pago",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 derive(canal = 'Sucursal') ~> derivedColumn5",
				"derivedColumn5 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['ventas_sc_limpio.csv'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}
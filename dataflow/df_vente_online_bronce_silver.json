{
	"name": "df_vente_online_bronce_silver",
	"properties": {
		"folder": {
			"name": "Bronce"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "Ventas_online_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          order_id as string,",
				"          timestamp as string,",
				"          product as string,",
				"          qty as string,",
				"          unit_price as string,",
				"          {customer/name} as string,",
				"          {customer/email} as string,",
				"          {customer/city} as string,",
				"          payment_method as string,",
				"          status as string,",
				"          shipping_cost as string,",
				"          channel as string,",
				"          customer as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 select(mapColumn(",
				"          id_venta = order_id,",
				"          fecha = timestamp,",
				"          producto = product,",
				"          cantidad = qty,",
				"          precio_unitario = unit_price,",
				"          nombre_cliente = {customer/name},",
				"          email_cliente = {customer/email},",
				"          ciudad = {customer/city},",
				"          motodo_pago = payment_method,",
				"          estado = status,",
				"          costo_envio = shipping_cost,",
				"          canal = channel,",
				"          cliente = customer",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1"
			]
		}
	}
}
{
	"name": "df_venta_lpz_bronce_silver",
	"properties": {
		"folder": {
			"name": "Bronce"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "Ventas_LPZ_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ventas_sc_limpio_csv",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "select1"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "derivedColumn4"
				},
				{
					"name": "derivedColumn5"
				},
				{
					"name": "filter1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ID_Venta as string,",
				"          Fecha_Venta as string,",
				"          Producto as string,",
				"          Cant as string,",
				"          PrecioUnit as string,",
				"          Sucursal as string,",
				"          Vendedor as string,",
				"          NombreCliente as string,",
				"          EmailCliente as string,",
				"          MetodoPago as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 select(mapColumn(",
				"          id_venta = ID_Venta,",
				"          fecha = Fecha_Venta,",
				"          producto = Producto,",
				"          cantidad = Cant,",
				"          precio_unitario = PrecioUnit,",
				"          sucursal = Sucursal,",
				"          vendedor = Vendedor,",
				"          cliente_nombre = NombreCliente,",
				"          cliente_email = EmailCliente,",
				"          metodo_pago = MetodoPago",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 derive(id_venta = trim(id_venta),",
				"          fecha = trim(fecha),",
				"          producto = trim(producto),",
				"          cantidad = trim(cantidad),",
				"          precio_unitario = trim(precio_unitario),",
				"          sucursal = trim(sucursal),",
				"          vendedor = trim(vendedor),",
				"          nombre_cliente = trim(cliente_nombre),",
				"          email_cliente = trim(cliente_email),",
				"          metodo_pago = trim(metodo_pago)) ~> derivedColumn1",
				"derivedColumn1 derive(sucursal = iif(\r",
				"    in(['LPZ','La Paz','la paz','lpz','Lpz','LA PAZ','lapaz','LaPaz','L.P.'],sucursal),'La Paz',sucursal\r",
				"),",
				"          canal = 'Sucursal') ~> derivedColumn2",
				"derivedColumn2 derive(fecha = coalesce(\r",
				"    toDate(fecha, 'yyyy-MM-dd'),\r",
				"    toDate(fecha, 'dd-MM-yyyy'),\r",
				"    toDate(fecha, 'MM-dd-yyyy'),\r",
				"    toDate(fecha, 'dd/MM/yyyy'),\r",
				"    toDate(fecha, 'yyyy/MM/dd'),\r",
				"    toDate(fecha, 'dd-MMM-yyyy'),\r",
				"    toDate(fecha, 'dd/MMM/yyyy'),\r",
				"\r",
				"    /* 👇 NUEVO formato tipo \"January 09, 2024\" */\r",
				"    toDate(fecha, 'MMMM dd, yyyy'),\r",
				"\r",
				"    /* 👇 manejo de fechas con texto tipo \"07 de abril de 2024\" */\r",
				"    toDate(\r",
				"        replace(\r",
				"            replace(\r",
				"                replace(\r",
				"                    replace(\r",
				"                        replace(\r",
				"                            replace(\r",
				"                                replace(\r",
				"                                    replace(\r",
				"                                        replace(\r",
				"                                            replace(\r",
				"                                                replace(\r",
				"                                                    replace(\r",
				"                                                        replace(fecha, ' de ', ' '),\r",
				"                                                        'enero','january'\r",
				"                                                    ),\r",
				"                                                    'febrero','february'\r",
				"                                                ),\r",
				"                                                'marzo','march'\r",
				"                                            ),\r",
				"                                            'abril','april'\r",
				"                                        ),\r",
				"                                        'mayo','may'\r",
				"                                    ),\r",
				"                                    'junio','june'\r",
				"                                ),\r",
				"                                'julio','july'\r",
				"                            ),\r",
				"                            'agosto','august'\r",
				"                        ),\r",
				"                        'septiembre','september'\r",
				"                    ),\r",
				"                    'octubre','october'\r",
				"                ),\r",
				"                'noviembre','november'\r",
				"            ),\r",
				"            'auguts','august'\r",
				"        ),\r",
				"        'dd MMMM yyyy'\r",
				"    )\r",
				")) ~> derivedColumn3",
				"derivedColumn3 derive(cantidad = toInteger(cantidad),",
				"          precio_unitario = toFloat(regexReplace(toString(precio_unitario), '[^0-9.]', ' ')),",
				"          producto = replace(producto, '\"', '')) ~> derivedColumn4",
				"derivedColumn4 derive(producto = initCap(regexReplace(producto,'\\\\s+',' '))) ~> derivedColumn5",
				"derivedColumn5 filter(cantidad>0 && !isNull (precio_unitario) && !isNull (fecha) && !isNull (metodo_pago)) ~> filter1",
				"filter1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['ventas_lpz_limpio.csv'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}